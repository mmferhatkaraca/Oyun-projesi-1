<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- NATIVE JAVA ENGINE VIEW -->
    <com.orbita.rokclone.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- TOP HUD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#99000000"
        android:padding="10dp"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/txtFood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YİYECEK: 500"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginEnd="40dp"/>

        <TextView
            android:id="@+id/txtWood"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ODUN: 1000"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- BOTTOM BAR -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="bottom|end"
        android:padding="20dp">

        <Button
            android:id="@+id/btnBuildFarm"
            android:layout_width="160dp"
            android:layout_height="70dp"
            android:text="ÇİFTLİK KUR\n(100 Odun)"
            android:backgroundTint="#8B4513"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

</FrameLayout>
