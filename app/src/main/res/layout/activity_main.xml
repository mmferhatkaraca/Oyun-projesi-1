<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0C10">

    <!-- THE GAME RENDERER (SurfaceView) -->
    <com.orbita.flowarena.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible" />

    <!-- MAIN MENU -->
    <LinearLayout
        android:id="@+id/menuUI"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#EE0B0C10"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ORBITA"
            android:textColor="#00D2D3"
            android:textSize="56sp"
            android:textStyle="bold"
            android:shadowColor="#00D2D3"
            android:shadowRadius="25"
            android:shadowDx="0"
            android:shadowDy="0"
            android:letterSpacing="0.1"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="FLOW ARENA"
            android:textColor="#C8D6E5"
            android:textSize="18sp"
            android:letterSpacing="0.3"
            android:layout_marginBottom="60dp"/>

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="250dp"
            android:layout_height="70dp"
            android:text="YOLCULUĞA BAŞLA"
            android:textSize="18sp"
            android:textColor="#00D2D3"
            android:backgroundTint="#2200D2D3"
            android:layout_marginBottom="20dp"
            android:stateListAnimator="@null"/>
            
    </LinearLayout>

    <!-- IN-GAME HUD -->
    <RelativeLayout
        android:id="@+id/hudUI"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/lblLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL 1"
            android:textColor="#00D2D3"
            android:textSize="28sp"
            android:textStyle="bold"
            android:shadowColor="#00D2D3"
            android:shadowRadius="10"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/lblPins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:shadowColor="#FFFFFF"
            android:shadowRadius="10"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="space_evenly"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="30dp">

            <Button
                android:id="@+id/btnShield"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:paddingHorizontal="20dp"
                android:text="KALKAN (3)"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#1DD1A1"/>

            <Button
                android:id="@+id/btnRisk"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:paddingHorizontal="20dp"
                android:text="RİSK MODU"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="#FF4757"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- RESULT UI -->
    <LinearLayout
        android:id="@+id/resultUI"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#F50B0C10"
        android:visibility="gone">

        <TextView
            android:id="@+id/lblResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL TAMAMLANDI"
            android:textColor="#1DD1A1"
            android:textSize="36sp"
            android:textStyle="bold"
            android:shadowColor="#1DD1A1"
            android:shadowRadius="20"
            android:layout_marginBottom="40dp"
            android:textAlignment="center"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="220dp"
            android:layout_height="70dp"
            android:text="SONRAKİ LEVEL"
            android:textSize="18sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00D2D3"/>
    </LinearLayout>

</FrameLayout>
