<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0b0c10">

    <!-- Native Game Engine View -->
    <com.orbita.flowarena.GameView
        android:id="@+id/gameView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- MENU UI -->
    <LinearLayout
        android:id="@+id/menuUI"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#DD0b0c10"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ORBITA"
            android:textColor="#00d2d3"
            android:textSize="50sp"
            android:textStyle="bold"
            android:shadowColor="#00d2d3"
            android:shadowRadius="15"
            android:shadowDx="0"
            android:shadowDy="0"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ANADOLU BİLİMKURGU"
            android:textColor="#c8d6e5"
            android:textSize="16sp"
            android:letterSpacing="0.2"
            android:layout_marginBottom="50dp"/>

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="250dp"
            android:layout_height="60dp"
            android:text="OYNA"
            android:textSize="20sp"
            android:textColor="#00d2d3"
            android:backgroundTint="#1A00d2d3"
            android:layout_marginBottom="15dp"/>
    </LinearLayout>

    <!-- HUD UI -->
    <RelativeLayout
        android:id="@+id/hudUI"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/lblLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL 1"
            android:textColor="#00d2d3"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_alignParentTop="true"
            android:layout_alignParentStart="true"/>

        <TextView
            android:id="@+id/lblPins"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kalan: 10"
            android:textColor="#ffffff"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnShield"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KALKAN (3)"
                android:backgroundTint="#1dd1a1"/>

            <Button
                android:id="@+id/btnRisk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RİSK x2"
                android:backgroundTint="#ff4757"/>
        </LinearLayout>
    </RelativeLayout>

    <!-- RESULT UI -->
    <LinearLayout
        android:id="@+id/resultUI"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#EE0b0c10"
        android:visibility="gone">

        <TextView
            android:id="@+id/lblResultTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="LEVEL GEÇİLDİ!"
            android:textColor="#1dd1a1"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="200dp"
            android:layout_height="60dp"
            android:text="DEVAM ET"
            android:textSize="20sp"
            android:textColor="#ffffff"
            android:backgroundTint="#00d2d3"/>
    </LinearLayout>

</FrameLayout>
